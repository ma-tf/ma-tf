{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "fallow": {
      "type": "local",
      "command": ["npx", "-y", "fallow-mcp"],
      "enabled": true,
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
    },
  },
  "plugin": ["opencode-dynamic-context-pruning"],
}
