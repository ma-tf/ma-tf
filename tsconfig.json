{
  "extends": "astro/tsconfigs/strictest",
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "types": ["astro/client"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowArbitraryExtensions": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", ".astro/types.d.ts"],
  "exclude": ["dist"]
}
